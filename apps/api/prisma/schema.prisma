generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  ADMIN
  MODERATOR
  ACCOUNTANT
  VENDOR
  CUSTOMER
}

enum VendorStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SUSPENDED
}

enum BranchStatus {
  ACTIVE
  SUSPENDED
  UNDER_REVIEW
}

enum City {
  AMMAN
  IRBID
  AQABA
}

enum ServiceType {
  HOT_DESK
  PRIVATE_OFFICE
  MEETING_ROOM
  EVENT_SPACE
}

enum PricingInterval {
  HOURLY
  HALF_DAY
  DAILY
  WEEKLY
  MONTHLY
}

enum PricingMode {
  PER_BOOKING
  PER_PERSON
  PER_HOUR
}

enum BookingStatus {
  PENDING
  PENDING_APPROVAL
  CONFIRMED
  CHECKED_IN
  COMPLETED
  NO_SHOW
  CANCELLED
  REJECTED
  EXPIRED
}

enum PaymentMethod {
  APPLE_PAY
  VISA
  MASTERCARD
  CASH
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ApprovalRequestType {
  VENDOR_REGISTRATION
  CAPACITY_CHANGE
  BRANCH_SUSPENSION
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  VENDOR_APPROVED
  VENDOR_REJECTED
  APPROVAL_REQUEST
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  GENERAL
}

enum QuotationStatus {
  NOT_SENT
  SENT
  ACCEPTED
  REJECTED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

enum EntityType {
  COMPANY
  INDIVIDUAL
}

enum Gender {
  MALE
  FEMALE
}

enum LegalDocType {
  NATIONAL_ID
  PASSPORT
}

enum CustomerClassification {
  LEVEL_0
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LEVEL_4
  LEVEL_5
  LEVEL_6
}

enum EntityRoleName {
  OPERATOR
  LESSOR
  OWNER
  EMPLOYEE
  MAINTENANCE
  RECEPTION
  TENANT
  LEGAL
  BOOKING
  CUSTOMER_CARE
}

enum DepartmentType {
  FINANCE
  LEGAL
  OPERATIONS
  MARKETING
  HR
  IT
  SALES
  CUSTOMER_SERVICE
}

enum RoomShape {
  L_SHAPE
  U_SHAPE
  RECTANGLE
  SQUARE
  OVAL
  CUSTOM
}

enum SetupType {
  CLASSROOM
  THEATER
  BOARDROOM
  U_SHAPE_SEATING
  HOLLOW_SQUARE
  BANQUET
}

enum DiscountType {
  NONE
  PERCENTAGE
  FIXED
  PROMO_CODE
}

// ==================== AUTH MODELS ====================

model User {
  id                     String                  @id @default(uuid())
  email                  String?                 @unique
  emailVerified          DateTime?
  phone                  String?                 @unique
  passwordHash           String?
  name                   String?
  image                  String?
  role                   Role                    @default(CUSTOMER)
  isActive               Boolean                 @default(true)
  // Phase 8: Entity enhancements
  entityType             EntityType?
  nationality            String?
  gender                 Gender?
  preferredLanguage      String?                 @default("en")
  legalDocType           LegalDocType?
  legalDocNumber         String?
  alternativeMobile      String?
  customerClassification CustomerClassification?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  // Relations
  accounts              Account[]
  sessions              Session[]
  vendorProfile         VendorProfile?
  bookings              Booking[]
  notifications         Notification[]
  otpCodes              OtpCode[]
  reviews               Review[]
  favorites             Favorite[]
  adminAuditLogs        AdminAuditLog[]
  paymentLogs           PaymentLog[]            @relation("PaymentLogPerformer")
  customerQuotations    Quotation[]             @relation("CustomerQuotations")
  createdQuotations     Quotation[]             @relation("QuotationCreatedBy")
  invoices              Invoice[]
  entityRoles           UserEntityRole[]

  @@index([email])
  @@index([phone])
  @@index([role])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  provider          String // google, credentials
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  tokenType         String?
  scope             String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String?
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, code])
}

// ==================== VENDOR & BRANCH ====================

model VendorProfile {
  id               String       @id @default(uuid())
  userId           String       @unique
  companyName      String
  description      String?
  logo             String?
  phone            String?
  website          String?
  images           String[]
  socialLinks      Json? // { instagram: "...", facebook: "...", linkedin: "...", twitter: "...", tiktok: "..." }
  agreedToTermsAt  DateTime?
  rejectionReason  String?
  status           VendorStatus @default(PENDING_APPROVAL)
  isVerified       Boolean      @default(false)
  verifiedAt       DateTime?
  verificationNote        String?
  verificationRequestedAt DateTime?
  commissionRate   Float?
  // Phase 8: Company enhancements
  companyLegalName          String?
  companyShortName          String?
  companyTradeName          String?
  companyNationalId         String?
  companyRegistrationNumber String?
  companyRegistrationDate   DateTime?
  companySalesTaxNumber     String?
  registeredInCountry       String?
  hasTaxExemption           Boolean  @default(false)
  companyDescription        String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  taxRate              Decimal   @default(16.00) @db.Decimal(5, 2)
  taxEnabled           Boolean   @default(true)

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  branches             Branch[]
  promoCodes           PromoCode[]
  approvalRequests     ApprovalRequest[]
  authorizedSignatories AuthorizedSignatory[]
  companyContacts      CompanyContact[]
  departmentContacts   DepartmentContact[]
  bankingInfo          BankingInfo[]
  addOns               VendorAddOn[]

  @@index([status])
}

model Branch {
  id                 String       @id @default(uuid())
  vendorProfileId    String
  name               String
  city               City
  address            String
  description        String?
  phone              String?
  email              String?
  latitude           Float?
  longitude          Float?
  images             String[] // Array of image URLs
  operatingHours     Json? // Weekly schedule: { monday: { open: "09:00", close: "18:00" }, ... }
  amenities          String[] // Per-branch facilities (WiFi, Parking, etc.)
  googleMapsUrl      String?
  autoAcceptBookings Boolean      @default(true)
  status             BranchStatus @default(ACTIVE)
  // Phase 9: Property enhancements
  grossArea          Decimal?     @db.Decimal(10, 2)
  receptionMobile    String?
  receptionEmail     String?
  profileUrl         String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  vendor           VendorProfile     @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  services         Service[]
  bookings         Booking[]
  approvalRequests ApprovalRequest[]
  reviews          Review[]
  favorites        Favorite[]
  promoCodes       PromoCode[]
  quotations       Quotation[]

  @@index([vendorProfileId])
  @@index([city])
  @@index([status])
}

// ==================== SERVICES & PRICING ====================

model Service {
  id          String      @id @default(uuid())
  branchId    String
  type        ServiceType
  name        String // e.g. "Hot Desk Area A", "Office Room 3"
  unitNumber  String? // e.g. "Room 3", "A-101"
  description String?
  capacity    Int? // Legacy/fallback capacity; prefer setupConfigs for min/max per setup
  isActive    Boolean     @default(true)
  // Phase 9: Unit detail enhancements
  profileNameEn String?
  profileNameAr String?
  weight        Int?
  netSize       Decimal?  @db.Decimal(10, 2)
  floor         String?
  shape         RoomShape?
  features      String[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  branch       Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  pricing      ServicePricing[]
  setupConfigs ServiceSetupConfig[]
  bookings     Booking[]
  quotations   Quotation[]

  @@index([branchId])
  @@index([type])
  @@index([branchId, type])
}

model ServiceSetupConfig {
  id        String    @id @default(uuid())
  serviceId String
  setupType SetupType
  minPeople Int       @default(1)
  maxPeople Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, setupType])
  @@index([serviceId])
}

model ServicePricing {
  id          String          @id @default(uuid())
  serviceId   String
  interval    PricingInterval
  pricingMode PricingMode     @default(PER_BOOKING)
  price       Decimal         @db.Decimal(10, 3) // JOD supports 3 decimal places (fils)
  currency    String          @default("JOD")
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, interval])
  @@index([serviceId])
}

// ==================== BOOKINGS & PAYMENTS ====================

model Booking {
  id                   String        @id @default(uuid())
  userId               String
  branchId             String
  serviceId            String
  status               BookingStatus @default(PENDING)
  startTime            DateTime
  endTime              DateTime
  numberOfPeople       Int           @default(1)
  totalPrice           Decimal       @db.Decimal(10, 3)
  currency             String        @default("JOD")
  notes                String?
  requestedSetup       SetupType?
  // Phase 3: Status view enhancements
  archivedAt           DateTime?
  salesApproved        Boolean       @default(false)
  accountantApproved   Boolean       @default(false)
  // Financial fields
  pricingInterval      PricingInterval?
  unitPrice            Decimal?      @db.Decimal(10, 3)
  subtotal             Decimal?      @db.Decimal(10, 3)
  discountType         DiscountType  @default(NONE)
  discountValue        Decimal?      @db.Decimal(10, 3)
  discountAmount       Decimal?      @db.Decimal(10, 3)
  taxRate              Decimal?      @db.Decimal(5, 2)
  taxAmount            Decimal?      @db.Decimal(10, 3)
  promoCodeId          String?
  bookingGroupId       String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch    Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  service   Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  payment   Payment?
  review    Review?
  quotation Quotation?
  invoices  Invoice[]
  addOns    BookingAddOn[]
  promoCode PromoCode?    @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([branchId])
  @@index([serviceId])
  @@index([status])
  @@index([startTime, endTime])
  @@index([bookingGroupId])
}

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  amount        Decimal       @db.Decimal(10, 3)
  currency      String        @default("JOD")
  transactionId String? // External gateway transaction ID
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  booking     Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  paymentLogs PaymentLog[]

  @@index([status])
  @@index([transactionId])
}

model PaymentLog {
  id            String   @id @default(uuid())
  paymentId     String
  action        String   // COLLECTED, REFUNDED, CREATED
  performedById String
  receiptNumber String?
  notes         String?
  details       String?  // System-generated detail string
  createdAt     DateTime @default(now())

  payment     Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  performedBy User    @relation("PaymentLogPerformer", fields: [performedById], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([performedById])
}

// ==================== QUOTATIONS ====================

model Quotation {
  id              String          @id @default(uuid())
  referenceNumber String          @unique
  customerId      String
  customer        User            @relation("CustomerQuotations", fields: [customerId], references: [id])
  branchId        String
  branch          Branch          @relation(fields: [branchId], references: [id])
  serviceId       String
  service         Service         @relation(fields: [serviceId], references: [id])
  startTime       DateTime
  endTime         DateTime
  numberOfPeople  Int             @default(1)
  totalAmount     Decimal         @db.Decimal(10, 2)
  status          QuotationStatus @default(NOT_SENT)
  notes           String?
  sentAt          DateTime?
  createdById     String
  createdBy       User            @relation("QuotationCreatedBy", fields: [createdById], references: [id])
  bookingId       String?         @unique
  booking         Booking?        @relation(fields: [bookingId], references: [id])
  // Financial fields
  subtotal        Decimal?        @db.Decimal(10, 3)
  discountType    DiscountType    @default(NONE)
  discountValue   Decimal?        @db.Decimal(10, 3)
  discountAmount  Decimal?        @db.Decimal(10, 3)
  taxRate         Decimal?        @db.Decimal(5, 2)
  taxAmount       Decimal?        @db.Decimal(10, 3)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  lineItems       QuotationLineItem[]

  @@index([customerId])
  @@index([branchId])
  @@index([status])
}

// ==================== INVOICES ====================

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  bookingId     String
  booking       Booking       @relation(fields: [bookingId], references: [id])
  customerId    String
  customer      User          @relation(fields: [customerId], references: [id])
  amount        Decimal       @db.Decimal(10, 2)
  taxAmount     Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount   Decimal       @db.Decimal(10, 2)
  status        InvoiceStatus @default(DRAFT)
  issuedAt      DateTime?
  dueDate       DateTime?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([customerId])
  @@index([bookingId])
  @@index([status])
}

// ==================== APPROVAL SYSTEM ====================

model ApprovalRequest {
  id              String                @id @default(uuid())
  branchId        String?
  vendorProfileId String?
  type            ApprovalRequestType
  status          ApprovalRequestStatus @default(PENDING)
  description     String // What change is requested
  details         Json? // Structured data about the change
  reason          String? // Rejection reason (filled by admin)
  reviewedBy      String? // Admin user ID who reviewed
  reviewedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  branch        Branch?        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  vendorProfile VendorProfile? @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([vendorProfileId])
  @@index([status])
  @@index([type])
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  data      Json? // Additional data (booking ID, etc.)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ==================== REVIEWS & FAVORITES ====================

model Review {
  id             String    @id @default(uuid())
  userId         String
  branchId       String
  bookingId      String?   @unique
  rating         Int // 1-5
  comment        String?
  vendorReply    String?
  replyCreatedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch  Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@unique([userId, branchId])
  @@index([branchId, createdAt])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  branchId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([userId])
}

// ==================== PROMOTIONS ====================

model PromoCode {
  id              String    @id @default(uuid())
  code            String    @unique
  discountPercent Int // e.g. 10 for 10%
  maxUses         Int       @default(0) // 0 means unlimited
  currentUses     Int       @default(0)
  validUntil      DateTime?
  isActive        Boolean   @default(true)

  vendorProfileId String
  vendorProfile   VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]

  @@index([vendorProfileId])
  @@index([code])
}

model SystemSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminAuditLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  details   String?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

// ==================== ENTITY MANAGEMENT (Phase 8) ====================

model EntityRole {
  id    String         @id @default(uuid())
  name  EntityRoleName @unique
  users UserEntityRole[]
}

model UserEntityRole {
  id           String     @id @default(uuid())
  userId       String
  entityRoleId String
  createdAt    DateTime   @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityRole EntityRole @relation(fields: [entityRoleId], references: [id], onDelete: Cascade)

  @@unique([userId, entityRoleId])
  @@index([userId])
}

model AuthorizedSignatory {
  id              String       @id @default(uuid())
  vendorProfileId String
  fullName        String
  nationality     String?
  legalDocType    LegalDocType?
  legalDocNumber  String?
  mobile          String?
  email           String?
  gender          Gender?
  idFileUrl       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  @@index([vendorProfileId])
}

model CompanyContact {
  id              String  @id @default(uuid())
  vendorProfileId String
  contactPersonName String?
  mobile          String?
  email           String?
  website         String?
  phone           String?
  fax             String?
  logoUrl         String?
  profileFileUrl  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  @@index([vendorProfileId])
}

model DepartmentContact {
  id              String         @id @default(uuid())
  vendorProfileId String
  department      DepartmentType
  contactName     String?
  mobile          String?
  phone           String?
  email           String?
  fax             String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  @@index([vendorProfileId])
}

model BankingInfo {
  id                    String  @id @default(uuid())
  vendorProfileId       String
  bankName              String?
  bankBranch            String?
  accountNumber         String?
  iban                  String?
  swiftCode             String?
  accountantManagerName String?
  cliq                  String?
  signatureUrl          String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  @@index([vendorProfileId])
}

// ==================== VENDOR ADD-ONS ====================

model VendorAddOn {
  id              String        @id @default(uuid())
  vendorProfileId String
  name            String
  nameAr          String?
  unitPrice       Decimal       @db.Decimal(10, 3)
  currency        String        @default("JOD")
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  vendorProfile   VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  bookingAddOns   BookingAddOn[]

  @@index([vendorProfileId])
}

model BookingAddOn {
  id            String       @id @default(uuid())
  bookingId     String
  vendorAddOnId String?
  name          String
  unitPrice     Decimal      @db.Decimal(10, 3)
  quantity      Int          @default(1)
  totalPrice    Decimal      @db.Decimal(10, 3)
  serviceTime   String?
  comments      String?
  createdAt     DateTime     @default(now())

  booking       Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  vendorAddOn   VendorAddOn? @relation(fields: [vendorAddOnId], references: [id], onDelete: SetNull)

  @@index([bookingId])
}

model QuotationLineItem {
  id          String    @id @default(uuid())
  quotationId String
  description String
  unitPrice   Decimal   @db.Decimal(10, 3)
  quantity    Int       @default(1)
  totalPrice  Decimal   @db.Decimal(10, 3)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}
