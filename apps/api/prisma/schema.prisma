generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  role      String   // ADMIN, VENDOR, CUSTOMER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  vendorProfile VendorProfile?
}

model VendorProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  companyName String
  status      String   @default("PENDING_APPROVAL") // DRAFT, PENDING_APPROVAL, APPROVED, REJECTED
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branches    Branch[]
}

model Branch {
  id              String   @id @default(uuid())
  vendorProfileId String
  name            String
  city            String   // Amman, Irbid, Aqaba
  address         String
  
  vendor          VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
}
